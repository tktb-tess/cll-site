---
import '../styles/globals.css';
import Head from '../layouts/Head.astro';
import Toc from '../components/Toc.astro';
import JboLogo from '../assets/JboLogo.svg';
import ToTopBtn from '../components/ToTopBtn.astro';
import pageData from '../assets/page_data';
import MyFooter from '../layouts/MyFooter.astro';
import type { H2Content } from '../modules/decl';

const contents = [...pageData].slice(1).map(([url, d]): H2Content => {
  return {
    text: d.longTitle ?? d.title,
    url,
    h3: [],
  };
});

const url = Astro.originPathname;
const title = pageData.get(url)?.title ?? '[NO DATA]';
---

<!doctype html>
<html lang='en'>
  <Head {title} {url} />
  <body>
    <main>
      <h1 id='title'>
        The <span class='text-red-600'>C</span>omplete
        <span class='text-blue-600'>L</span>ojban
        <span class='text-red-600'>L</span>anguage Viewer
      </h1>
      <JboLogo
        class='max-inline-95 inline-full mx-auto my-figure [&_#path-1]:fill-[#00f] [&_#path-2]:fill-[#f00]'
      />
      <Toc {contents} />
    </main>
    <footer>
      <MyFooter />
    </footer>
    <ToTopBtn />
  </body>
</html>

<style lang="postcss">
  @reference '../styles/globals.css';
  @layer properties, theme, base, components, utilities;
  
  @layer components {
    main {
      @apply flow-root bg-main inline-full max-inline-7xl mx-auto px-4 lg:px-6 pbe-36;
    }

    #title {
      @apply text-center border-none;
    }

    footer {
      @apply flex flex-col items-center *:min-inline-0 block-max px-2 py-1;
    }
  }
</style>
