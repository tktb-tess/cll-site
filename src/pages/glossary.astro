---
import Layout from '../layouts/Layout.astro';
import Search from '../components/Search.astro';
---

<Layout>
  <Search />
</Layout>

<style lang="postcss">
  @reference '../styles/globals.css';
  @layer components {
    body {
      @apply flow-root lg:grid min-block-lvh;

      grid-template-areas: 
        'h h h'
        'l m r'
        'f f f';

      grid-template-columns:
        minmax(min(var(--spacing-min-side), 50%), 1fr)
        minmax(0, var(--spacing-max-main))
        minmax(min(var(--spacing-min-side), 50%), 1fr);
      grid-template-rows: auto 1fr auto;
    }

    header {
      @apply block-header sticky inset-bs-0 z-header;
      grid-area: h;
    }

    .__lside {
      grid-area: l;
    }

    .__rside {
      grid-area: r;
    }

    .__lside, .__rside {
      @apply max-lg:hidden;
    }

    .__sidebar-root {
      @apply block-[calc(100lvh-var(--spacing-header))] overflow-y-auto sticky 
      inset-bs-header z-sidebar px-1 py-2;
      scrollbar-width: thin;
    }

    main {
      @apply flow-root bg-main px-4 pbe-8 min-block-lvh;
      grid-area: m;
    }

    footer {
      @apply flex flex-col items-center *:min-inline-0 block-max px-2 py-1;
      grid-area: f;
    }
  }
</style>
