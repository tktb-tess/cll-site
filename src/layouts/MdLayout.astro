---
import Layout from './Layout.astro';
import type { MarkdownLayoutProps } from 'astro';
import type { PageData } from '../assets/page_data';
import { getContents } from '../modules/funcs';

type Props = MarkdownLayoutProps<{
  readonly title: string;
  readonly description?: string;
}>;

const { frontmatter, headings } = Astro.props;
const path = Astro.originPathname;

const shortTitle =
  frontmatter.title.match(/Chapter\s\d+/u)?.[0] ?? frontmatter.title;


const contents = getContents(headings, path);

const pageData = {
  title: shortTitle,
  longTitle: frontmatter.title,
  description: frontmatter.description,
} satisfies PageData;
---

<Layout {pageData} {contents}>
  <slot />
</Layout>

<style lang="postcss">
  @reference '../styles/globals.css';
  @layer components {
    body {
      @apply flow-root lg:grid min-block-lvh;

      grid-template-areas: 
        'h h h'
        'l m r'
        'f f f';

      grid-template-columns:
        minmax(min(var(--spacing-min-side), 50%), 1fr)
        minmax(0, var(--spacing-max-main))
        minmax(min(var(--spacing-min-side), 50%), 1fr);
      grid-template-rows: auto 1fr auto;
    }

    .header {
      @apply block-header sticky top-0 z-header;
      grid-area: h;
    }

    .lside {
      grid-area: l;
    }

    .rside {
      grid-area: r;
    }

    .lside, .rside {
      @apply max-lg:hidden;
    }

    .sidebar-root {
      @apply block-[calc(100lvh-var(--spacing-header))] overflow-y-auto sticky 
      top-header z-sidebar px-1 py-2 overscroll-y-contain;
      scrollbar-width: thin;
    }

    .main {
      @apply flow-root bg-main px-4 pbe-8 min-block-lvh;
      grid-area: m;
    }

    .footer {
      @apply flex flex-col items-center *:min-inline-0 block-max px-2 py-1;
      grid-area: f;
    }
  }
</style>
